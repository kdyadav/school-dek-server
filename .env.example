# Postgres connection used by Prisma at runtime + migrations.
# On Render, this is provided automatically by the database in render.yaml.
DATABASE_URL=postgresql://skooldesk:skooldesk@localhost:5432/skooldesk?schema=public

# HTTP server. Render injects PORT at runtime; HOST must be 0.0.0.0.
PORT=4000
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins. Use '*' only for local dev.
# In production set this to your deployed UI origin (e.g. https://app.example.com).
CORS_ORIGIN=http://localhost:5173

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-please-use-a-long-random-value
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# File storage (logo / favicon). 'local' writes under STORAGE_LOCAL_DIR and
# serves them via PUBLIC_BASE_URL/uploads/<filename>. 's3' is reserved for
# later; not implemented in this phase.
# On Render, mount a persistent disk at STORAGE_LOCAL_DIR (see render.yaml)
# and set PUBLIC_BASE_URL to the service's https URL.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./var/uploads
PUBLIC_BASE_URL=http://localhost:4000
